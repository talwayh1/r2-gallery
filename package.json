{
  "name": "r2-gallery",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "cd web && npm run build && cd .. && wrangler deploy",
    "build:web": "cd web && npm run build",
    "db:init": "wrangler d1 execute r2-gallery-db --file=./migrations/0001_init.sql",
    "db:init:local": "wrangler d1 execute r2-gallery-db --local --file=./migrations/0001_init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.3.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/resize": "^2.1.1",
    "@jsquash/webp": "^1.5.0",
    "exifr": "^7.1.3",
    "hono": "^4.0.0"
  }
}
