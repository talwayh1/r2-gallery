# Environment variables for local development
# Copy this file to .env and fill in your values
# These are used by wrangler dev for local development

# Local admin credentials (auto-creates admin user on first launch)
ADMIN_PASSWORD=set-your-admin-password-here
# JWT signing secret (minimum 32 characters, use a random string)
JWT_SECRET=change-this-to-a-random-32-character-string
# Telegram Login Widget (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Demo mode -- set to true to skip authentication for local testing
DEMO_MODE=false

# Optional CDN domain for origin-pull (/cdn/* routes)
CDN_DOMAIN=
